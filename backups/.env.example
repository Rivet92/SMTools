# SMTools Backup — configuración (independiente del .env de deploy)
# Copia este archivo a /etc/smtools/backup.env en el servidor

# PostgreSQL credentials (mismas que en deploy/.env)
POSTGRES_USER=smtools
POSTGRES_PASSWORD=change_me
POSTGRES_DB=smtools

# GPG recipient (email o key ID de la clave pública importada)
#   gpg --list-keys  para ver el ID disponible
GPG_RECIPIENT=backup@smtools.test

# Scaleway Object Storage (o cualquier S3-compatible)
SCW_ACCESS_KEY=SCWXXXXXXXXXXXXX
SCW_SECRET_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
SCW_BUCKET=smtools-backups
AWS_ENDPOINT_URL=https://s3.fr-par.scw.cloud
AWS_DEFAULT_REGION=fr-par

# Contenedor y ruta de los avatares (opcional, valores por defecto)
# AVATAR_CONTAINER=smtools_app
# AVATAR_DIR=/app/wwwroot/avatars
