# Copy this file to .env and fill in your real values.
# The backend loads this file automatically in Development.
# For Docker/production, see deploy/.env.example instead.

# ---------------------------------------------------------------------------
# Development (used by pnpm dev / pnpm dev:backend)
# ---------------------------------------------------------------------------
ASPNETCORE_ENVIRONMENT=Development

# Backend port and URLs
BACKEND_PORT=5125
ASPNETCORE_URLS=http://+:${BACKEND_PORT}

# PostgreSQL credentials for the db service (docker-compose.yml)
POSTGRES_USER=smtools
POSTGRES_PASSWORD=smtools
POSTGRES_DB=smtools

# The connection string is auto-constructed from POSTGRES_USER/PASSWORD/DB above
# (plus optional POSTGRES_HOST and POSTGRES_PORT below, defaulting to localhost:5432).
# You only need to set ConnectionStrings__DefaultConnection manually if you
# want to override the auto-constructed value.
# POSTGRES_PORT=5432

# pgAdmin credentials (required when using pgAdmin in development)
PGADMIN_DEFAULT_EMAIL=admin@smtools.test
PGADMIN_DEFAULT_PASSWORD=smtools

# Backend URL for the frontend Vite proxy (VITE_ prefix makes it available to the browser)
VITE_BACKEND_URL=http://localhost:${BACKEND_PORT}

# Frontend dev server port
FRONTEND_DEV_PORT=8080

# Public origin of the frontend (Vite dev server). Used for CORS and OAuth callbacks.
FRONTEND_ORIGIN=http://localhost:${FRONTEND_DEV_PORT}

# Base URL path for the frontend. Use /app/ when deploying under a subpath.
BASE_URL=/

# OAuth 2.0 providers
# Google: https://console.cloud.google.com/apis/credentials
AUTHENTICATION__GOOGLE__CLIENTID=your_google_client_id
AUTHENTICATION__GOOGLE__CLIENTSECRET=your_google_client_secret

# GitHub: https://github.com/settings/developers
AUTHENTICATION__GITHUB__CLIENTID=your_github_client_id
AUTHENTICATION__GITHUB__CLIENTSECRET=your_github_client_secret

# Legal owner info (overrides defaults in legal page)
VITE_LEGAL_OWNER=Jaime Lerga
VITE_LEGAL_EMAIL=contacto@jlerga.dev

# Set to false to hide the demo disclaimer from the legal page
# VITE_SHOW_DISCLAIMER=true
