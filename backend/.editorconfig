root = true

[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.cs]
indent_size = 4
csharp_style_namespace_declarations = file_scoped:suggestion

[**/Migrations/**.cs]
# CA1861: Preferir campos "static readonly" frente a argumentos de matriz constantes
dotnet_diagnostic.CA1861.severity = none

# Las migraciones son archivos generados por EF Core; no forzamos formato de archivo sobre ellos.
charset = unset
insert_final_newline = unset
trim_trailing_whitespace = unset
