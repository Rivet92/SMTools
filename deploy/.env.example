# Copy this file to .env.docker and pass it to docker run --env-file.
# The entrypoint script reads these variables at container startup.
# Build-time variables (BASE_URL) must be passed via --build-arg.

# ---------------------------------------------------------------------------
# Runtime configuration for the Docker container
# ---------------------------------------------------------------------------

# PostgreSQL credentials for the db service
POSTGRES_USER=smtools
POSTGRES_PASSWORD=change_me
POSTGRES_DB=smtools
# Hostname of the PostgreSQL server (docker service name for compose, or your server)
POSTGRES_HOST=db
# POSTGRES_PORT=5432

# Port the container listens on. Sets both ASPNETCORE_URLS and the default FRONTEND_ORIGIN.
PORT=8080

# Public origin of the frontend. Used for CORS, OAuth callbacks, and SEO meta tags.
# Defaults to http://localhost:{PORT}
FRONTEND_ORIGIN=https://your-domain.com

# The connection string is auto-constructed from POSTGRES_USER/PASSWORD/DB/HOST/PORT above.
# You only need to set ConnectionStrings__DefaultConnection manually if you
# want to override the auto-constructed value.

# OAuth 2.0 providers
# Google: https://console.cloud.google.com/apis/credentials
AUTHENTICATION__GOOGLE__CLIENTID=your_google_client_id
AUTHENTICATION__GOOGLE__CLIENTSECRET=your_google_client_secret

# GitHub: https://github.com/settings/developers
AUTHENTICATION__GITHUB__CLIENTID=your_github_client_id
AUTHENTICATION__GITHUB__CLIENTSECRET=your_github_client_secret

# Legal owner info (runtime; written to /app/wwwroot/legal.js by the entrypoint)
# These are the only legal texts you typically need to customize per deployment.
LEGAL_OWNER=Jaime Lerga
LEGAL_EMAIL=contacto@jlerga.dev

# Set to false to hide the demo disclaimer from the legal page
# SHOW_DISCLAIMER=true
